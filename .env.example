# =====================================================================
# SNR EduOS — пример переменных окружения.
# Скопируй в .env и заполни значениями из дашборда Supabase.
# .env закоммичен в .gitignore — секреты НИКОГДА не попадают в git.
# =====================================================================

# --- Web (Next.js): публичные, безопасны для клиента ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Mobile (Expo): публичные, безопасны для клиента ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Только сервер / миграции: НЕ отдавать клиенту, НЕ коммитить ---
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# --- Supabase CLI (линковка проекта и миграции) ---
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# --- Домен синтетических email для username-логина (см. план §4) ---
# Ученик вводит username (напр. Adilbek_07) -> core мэппит в
# <username>@<STUDENT_EMAIL_DOMAIN> перед signInWithPassword.
STUDENT_EMAIL_DOMAIN=students.snr.local
